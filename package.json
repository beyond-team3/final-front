{
  "name": "seedflowplus",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run mock\"",
    "dev:frontend": "vite",
    "mock": "npm --prefix mock-server run start",
    "mock:reset": "cp mock-server/db.seed.json mock-server/db.json",
    "setup": "npm install && npm --prefix mock-server install",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vueuse/core": "^13.9.0",
    "axios": "^1.9.0",
    "chart.js": "^4.5.1",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.3",
    "vue": "^3.5.27",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
